{
  "name": "@your_service_name/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json && npm run generate-types",
    "start": "prisma migrate deploy && node dist/src/server.js",
    "seed": "npx vite-node prisma/seed.ts",
    "cleanup:s3": "npx vite-node src/batch/cleanup-s3.ts",
    "dev": "npm run build && npm run start",
    "generate-types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "generate-prisma": "npx prisma generate",
    "lint": "eslint ./src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"./backend/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "exports": {
    "./routers": "./dist/src/routers/index.js",
    "./schemas": "./dist/src/schemas/index.js",
    "./utils": "./dist/src/utils/index.js",
    "./prisma": "./dist/src/prisma/index.js",
    "./types": "./dist/src/types/jwt.js"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.670.0",
    "@aws-sdk/client-s3": "^3.667.0",
    "@aws-sdk/credential-provider-ini": "^3.670.0",
    "@aws-sdk/credential-provider-sso": "^3.667.0",
    "@aws-sdk/credential-providers": "^3.670.0",
    "@aws-sdk/s3-request-presigner": "^3.667.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^6.7.1",
    "@fastify/oauth2": "^7.8.0",
    "@fastify/session": "^10.7.0",
    "@prisma/client": "^5.21.1",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "bcrypt": "^5.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^4.26.2",
    "fastify-formbody": "^5.3.0",
    "fastify-prisma-client": "^6.0.0",
    "firebase": "^10.10.0",
    "sharp": "^0.34.1",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^18.19.50",
    "@types/stripe": "^8.0.417",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.0.2",
    "prettier": "^2.8.7",
    "prisma": "^5.20.0",
    "typescript": "^5.6.2",
    "vite-node": "^2.1.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
